# ════════════════════════════════════════════════════════════════
#  sweet_kernel-builder — Build Configuration
#  Device: Redmi Note 10 Pro (sweet) | Kernel: 4.14 | Arch: arm64
# ════════════════════════════════════════════════════════════════

# ─── Kernel Source ───────────────────────────────────────────────
KERNEL_REPO=https://github.com/yureixen/android_kernel_xiaomi_sm6150.git
KERNEL_BRANCH=sixteen-qpr2
KERNEL_DEFCONFIG=sweet_defconfig

# ─── KernelSU-Next ───────────────────────────────────────────────
# legacy-susfs branch = KSU-Next with SuSFS integration built-in
KERNELSU_BRANCH=legacy-susfs

# ─── AnyKernel3 ──────────────────────────────────────────────────
AK3_REPO=https://github.com/riarumoda/AnyKernel3.git
# NOTE: riarumoda-r AnyKernel3-e "sweet" branch na thakle "master"-e fallback hobe
AK3_BRANCH=sweet

# ─── Build ───────────────────────────────────────────────────────
ARCH=arm64
KERNEL_OUT=out
