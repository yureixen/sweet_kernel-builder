# ════════════════════════════════════════════════════════════════
#  config.env — Sweet Kernel Builder Configuration
#  Device: Redmi Note 10 Pro (sweet/sweetin)
#  Kernel: 4.14 | KernelSU-Next + SuSFS
# ════════════════════════════════════════════════════════════════

# ─── Kernel Source ───────────────────────────────────────────────
KERNEL_REPO=https://github.com/yureixen/android_kernel_xiaomi_sm6150.git
KERNEL_BRANCH=sixteen-qpr2
KERNEL_DEFCONFIG=sweet_defconfig
KERNEL_OUT=$HOME/kernel-build/kernel/out

# ─── KernelSU-Next ───────────────────────────────────────────────
KERNELSU_BRANCH=legacy-susfs

# ─── AnyKernel3 ──────────────────────────────────────────────────
AK3_REPO=https://github.com/osm0sis/AnyKernel3
AK3_BRANCH=master

# ─── Build Directories ───────────────────────────────────────────
KERNEL_DIR=$HOME/kernel-build/kernel
AK3_DIR=$HOME/kernel-build/AnyKernel3
CLANG_BIN=$HOME/toolchains/neutron-clang/bin
